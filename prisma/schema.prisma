generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int          @id @default(autoincrement())
  name      String
  email     String       @unique
  password  String
  role      Role         @default(USER)
  teams     TeamMember[]
  checkIns  CheckIn[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model Team {
  id          Int          @id @default(autoincrement())
  name        String
  description String?
  members     TeamMember[]
  checkIns    CheckIn[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model TeamMember {
  id        Int      @id @default(autoincrement())
  userId    Int
  teamId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, teamId])
}

model CheckIn {
  id        Int      @id @default(autoincrement())
  userId    Int
  teamId    Int
  mood      Mood
  workload  Workload
  comment   String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

enum Role {
  USER
  ADMIN
}

enum Mood {
  GREAT
  GOOD
  OK
  BAD
  TERRIBLE
}

enum Workload {
  LOW
  MEDIUM
  HIGH
  OVERLOADED
}